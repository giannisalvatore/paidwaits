# Server
PORT=4100
NODE_ENV=development

# MySQL (docker compose up -d nella root del progetto)
DATABASE_URL=mysql://root:waitingads@127.0.0.1:3308/waitingads

# Chiavi per la firma del cookie di sessione (separate da virgola per rotazione)
SESSION_KEYS=dev-only-change-me

# Origine del frontend autorizzata per CORS con credenziali
FRONTEND_ORIGIN=http://localhost:3000

# Google OAuth (vuoto = solo dev login)
GOOGLE_CLIENT_ID=

# Abilita POST /auth/dev (login senza Google, SOLO sviluppo)
DEV_LOGIN=true
